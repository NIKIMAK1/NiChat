{
	"schemaVersion": 1,
	"id": "nichat",
	"version": "${version}",
	"name": "NiChat",
	"description": "Mod for new chat history and pop-up messages from chat.",
	"authors": [
		"Nikita Maksimow"
	],
	"contact": {
		"sources": "https://github.com/NIKIMAK1/NiChat"
	},
	"license": "GNU GPLv3",
	"icon": "assets/nichat/icon.png",
	"environment": "*",
	"entrypoints": {
		"client": [
			{
				"value": "com.nichat.NiChatClient",
				"adapter": "kotlin"
			}
		]
	},
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}